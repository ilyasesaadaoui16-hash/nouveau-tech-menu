<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة NOUVEAU TECH</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Tajawal', sans-serif; background: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row">

    <aside class="w-full md:w-64 glass-panel flex flex-col p-5 space-y-6 md:h-screen sticky top-0">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-yellow-500 rounded-full flex items-center justify-center text-black font-bold text-xl">NT</div>
            <h1 class="text-xl font-bold text-yellow-500">الإدارة</h1>
        </div>
        <nav class="flex flex-col gap-2">
            <button onclick="showTab('orders')" id="btn-orders" class="text-right px-4 py-3 rounded-lg bg-yellow-500 text-black font-bold transition">🛒 الطلبات الحية</button>
            <button onclick="showTab('menu')" id="btn-menu" class="text-right px-4 py-3 rounded-lg hover:bg-white/10 text-gray-300 transition">🍔 إدارة المنيو</button>
        </nav>
    </aside>

    <main class="flex-1 p-6 md:p-10">
        
        <section id="orders-tab" class="space-y-6">
            <header class="flex justify-between items-center">
                <h2 class="text-2xl font-bold">الطلبات الواردة</h2>
                <button onclick="fetchOrders()" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm font-bold transition">🔄 تحديث الطلبات</button>
            </header>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="glass-panel p-4 rounded-xl text-center">
                    <h3 class="text-gray-400 text-sm">طلبات اليوم</h3>
                    <p class="text-2xl font-bold text-white mt-1">12</p>
                </div>
                <div class="glass-panel p-4 rounded-xl text-center">
                    <h3 class="text-gray-400 text-sm">المدخول اليومي</h3>
                    <p class="text-2xl font-bold text-yellow-500 mt-1">450 DH</p>
                </div>
            </div>

            <div class="glass-panel rounded-xl overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-white/5 border-b border-white/10 text-gray-300">
                        <tr>
                            <th class="p-4">الوقت</th>
                            <th class="p-4">الطاولة</th>
                            <th class="p-4">الأشخاص</th>
                            <th class="p-4">التفاصيل</th>
                            <th class="p-4">المجموع</th>
                            <th class="p-4">الإجراء</th>
                        </tr>
                    </thead>
                    <tbody id="orders-list" class="divide-y divide-white/5">
                        <tr class="hover:bg-white/5 transition">
                            <td class="p-4 text-sm text-gray-400">12:30 PM</td>
                            <td class="p-4 font-bold text-yellow-500">طاولة 5</td>
                            <td class="p-4">2</td>
                            <td class="p-4 text-sm">بيتزا مارغريتا x1, كولا x2</td>
                            <td class="p-4 font-bold">120 DH</td>
                            <td class="p-4">
                                <button class="bg-green-600/20 text-green-500 border border-green-600 px-3 py-1 rounded-md text-sm hover:bg-green-600 hover:text-white transition">تم التقديم</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="menu-tab" class="hidden space-y-6">
            <header class="flex justify-between items-center">
                <h2 class="text-2xl font-bold">إدارة قائمة الطعام</h2>
                <a href="https://docs.google.com/spreadsheets/d/e/2PACX-1vSIWHuGH6ncA4zp6A43RdxyxM3yibzV65Lpq4hdgc6NhVv4yjZfRpNfUFJMRbr6cP56Ds7oD9lye1B3/edit" target="_blank" class="bg-green-600 hover:bg-green-500 px-4 py-2 rounded-lg text-sm font-bold transition">📝 تعديل عبر Google Sheets</a>
            </header>
            <div class="glass-panel p-8 rounded-xl text-center">
                <p class="text-gray-300 mb-4">حالياً، يتم سحب المنتجات تلقائياً من ملف Google Sheets الخاص بك.</p>
                <p class="text-sm text-gray-500">لإضافة منتج جديد، أو تعديل سعر، أو تغيير صورة، يرجى الضغط على الزر أعلاه لفتح الملف والتعديل عليه مباشرة. ستتحدث القائمة عند الزبائن فوراً.</p>
            </div>
        </section>

    </main>

    <script>
        // دالة التبديل بين التبويبات
        function showTab(tabName) {
            // إخفاء الكل
            document.getElementById('orders-tab').classList.add('hidden');
            document.getElementById('menu-tab').classList.add('hidden');
            
            // تصفير الأزرار
            document.getElementById('btn-orders').className = "text-right px-4 py-3 rounded-lg hover:bg-white/10 text-gray-300 transition";
            document.getElementById('btn-menu').className = "text-right px-4 py-3 rounded-lg hover:bg-white/10 text-gray-300 transition";

            // إظهار المطلوب
            document.getElementById(tabName + '-tab').classList.remove('hidden');
            document.getElementById('btn-' + tabName).className = "text-right px-4 py-3 rounded-lg bg-yellow-500 text-black font-bold transition";
        }

        // دالة جلب الطلبات (تحتاج إلى إعداد في Google Apps Script)
        function fetchOrders() {
            alert('يجب ربط هذه الواجهة بكود Google Apps Script لجلب الطلبات الحية من الجدول.');
            // هنا سيتم وضع كود fetch() لجلب البيانات
        }
    </script>
</body>
</html>
